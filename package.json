{
  "name": "bourbonomics",
  "version": "2.6.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @bourbonomics/client",
    "build": "npm run build -w @bourbonomics/client",
    "preview": "npm run preview -w @bourbonomics/client",
    "test": "npm test --workspaces --if-present",
    "test:engine": "npm test -w @bourbonomics/engine",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.9.3"
  }
}
